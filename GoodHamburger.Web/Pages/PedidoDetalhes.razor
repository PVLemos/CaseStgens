@page "/pedido/{Id:int}"
@using GoodHamburger.Web.DTOs
@using GoodHamburger.Web.Models
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Detalhes do Pedido #@Id</PageTitle>

<div class="container pt-4">
    <div class="col-md-8 mx-auto">
        <div class="d-flex align-items-center mb-4">
            <button class="btn btn-link link-dark p-0 me-3" @onclick="Voltar">
                <i class="bi bi-arrow-left fs-4"></i>
            </button>
            <h2 class="fw-bold mb-0" style="color: var(--text-main);">Detalhes do Pedido</h2>
        </div>

        @if (carregando)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Carregando...</span>
                </div>
                <p class="mt-3 text-muted">Buscando informações do seu hambúrguer...</p>
            </div>
        }
        else if (pedido == null)
        {
            <div class="alert alert-warning rounded-4 border-0 shadow-sm p-4 text-center">
                <i class="bi bi-exclamation-circle fs-1 mb-3 d-block"></i>
                <h4 class="fw-bold">Pedido não encontrado</h4>
                <p>O número #@Id não corresponde a nenhum pedido em nosso sistema.</p>
                <a href="/cardapio" class="btn btn-primary mt-2 rounded-pill px-4">Ir para o Cardápio</a>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4">
                <div class="card-header @GetHeaderClass() text-white py-3 px-4 d-flex justify-content-between align-items-center border-0">
                    <h4 class="mb-0 fw-bold">Pedido #@pedido.Id</h4>
                    <span class="badge @GetBadgeClass() fs-6 px-3 py-2 rounded-pill shadow-sm">
                        @GetStatusNome()
                    </span>
                </div>
                <div class="card-body p-4 bg-white">
                    <div class="mb-4">
                        <h5 class="fw-bold border-bottom pb-2 mb-3">Resumo dos Itens</h5>
                        <ul class="list-unstyled">
                            @foreach (var item in pedido.Itens)
                            {
                                <li class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <div>
                                        <span class="fw-semibold">@item.Nome</span>
                                        <br />
                                        <small class="text-muted">@item.Categoria</small>
                                    </div>
                                    <span class="fw-bold">R$ @item.Preco.ToString("0.00")</span>
                                </li>
                            }
                        </ul>
                    </div>

                    <div class="bg-light p-4 rounded-4 mb-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted fw-semibold">Subtotal</span>
                            <span class="fw-bold">R$ @pedido.Subtotal.ToString("0.00")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-success fw-semibold">Desconto Aplicado</span>
                            <span class="text-success fw-bold">- R$ @pedido.Desconto.ToString("0.00")</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fs-4 fw-bold">Total Pago</span>
                            <span class="fs-4 fw-bold" style="color: var(--primary-color);">R$ @pedido.Total.ToString("0.00")</span>
                        </div>
                    </div>

                    @if (pedido.Status == "Pendente")
                    {
                        <div class="alert alert-info border-0 rounded-4 d-flex align-items-center mb-4">
                            <i class="bi bi-info-circle-fill fs-4 me-3"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Aguardando Pagamento</h6>
                                <p class="mb-0 small">Confirme o pagamento para que nossa cozinha comece a preparar seu pedido!</p>
                            </div>
                        </div>
                        
                        <button class="btn btn-success w-100 rounded-pill fw-bold py-3 shadow-sm hover-elevate" 
                                @onclick="Pagar" disabled="@processando">
                            @if (processando)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Processando Pagamento...</span>
                            }
                            else
                            {
                                <i class="bi bi-credit-card-fill me-2"></i>
                                <span>Confirmar Pagamento</span>
                            }
                        </button>
                    }
                    else if (pedido.Status == "Pago")
                    {
                        <div class="text-center py-3">
                            <div class="bg-success-subtle text-success p-3 rounded-4 mb-3 d-inline-block">
                                <i class="bi bi-clock-history fs-2"></i>
                            </div>
                            <h5 class="fw-bold">Pedido em Preparo!</h5>
                            <p class="text-muted">Nossos chefs já estão cuidando do seu hambúrguer. Fique de olho nesta tela para atualizações.</p>
                        </div>
                    }
                </div>
            </div>
            
            <div class="text-center">
                <button class="btn btn-outline-secondary rounded-pill px-4 fw-bold" @onclick="() => Navigation.NavigateTo(Navigation.Uri, true)">
                    <i class="bi bi-arrow-clockwise me-2"></i> Atualizar Status
                </button>
            </div>
        }
    </div>
</div>

<style>
    .glass-panel {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
    
    .hover-elevate {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    
    .hover-elevate:hover:not(:disabled) {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>

@code {
    [Parameter] public int Id { get; set; }
    private PedidoResponseDto? pedido;
    private bool carregando = true;
    private bool processando = false;

    protected override async Task OnInitializedAsync()
    {
        await CarregarPedido();
    }

    private async Task CarregarPedido()
    {
        try
        {
            carregando = true;
            pedido = await Http.GetFromJsonAsync<PedidoResponseDto>($"api/pedidos/{Id}");
        }
        catch (Exception)
        {
            pedido = null;
        }
        finally
        {
            carregando = false;
        }
    }

    private async Task Pagar()
    {
        processando = true;
        try
        {
            var result = await Http.PutAsync($"api/pedidos/{Id}/pagar", null);
            if (result.IsSuccessStatusCode)
            {
                await CarregarPedido();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao pagar: {ex.Message}");
        }
        finally
        {
            processando = false;
        }
    }

    private void Voltar() => Navigation.NavigateTo("/cardapio");

    private string GetHeaderClass() => pedido?.Status switch
    {
        "Pendente" => "bg-warning",
        "Pago" => "bg-success",
        "EmPreparo" => "bg-info",
        "Finalizado" => "bg-dark",
        _ => "bg-secondary"
    };

    private string GetBadgeClass() => pedido?.Status switch
    {
        "Pendente" => "bg-white text-warning",
        "Pago" => "bg-white text-success",
        "EmPreparo" => "bg-white text-info",
        _ => "bg-white text-secondary"
    };

    private string GetStatusNome() => pedido?.Status switch
    {
        "Pendente" => "Aguardando Pagamento",
        "Pago" => "Pago / Em Preparo",
        "EmPreparo" => "Sendo Preparado",
        "Finalizado" => "Entregue",
        "Cancelado" => "Cancelado",
        _ => pedido?.Status ?? "Desconhecido"
    };
}
