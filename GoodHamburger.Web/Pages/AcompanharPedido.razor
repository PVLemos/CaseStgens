@page "/acompanhar"
@inject NavigationManager Navigation

<PageTitle>Acompanhar Pedido</PageTitle>

<div class="container pt-5">
    <div class="col-md-6 mx-auto text-center">
        <div class="mb-5">
            <h1 class="fw-bold display-5 mb-3" style="color: var(--primary-color);">Rastrear Meu Pedido</h1>
            <p class="text-muted fs-5">Insira o número do seu pedido para ver o status em tempo real.</p>
        </div>

        <div class="card border-0 shadow-lg rounded-5 p-4 glass-panel">
            <div class="card-body">
                <div class="form-floating mb-4">
                    <input type="number" class="form-control form-control-lg border-0 shadow-sm rounded-4" 
                           id="pedidoId" placeholder="Ex: 123" @bind="pedidoId" @onkeyup="HandleKeyUp">
                    <label for="pedidoId">Número do Pedido (Ex: 1)</label>
                </div>

                <button class="btn btn-primary w-100 rounded-pill fw-bold py-3 shadow-sm hover-scale" 
                        @onclick="VerPedido" disabled="@(pedidoId <= 0)">
                    <i class="bi bi-search me-2"></i> Buscar Pedido
                </button>

                @if (erro)
                {
                    <div class="alert alert-danger mt-4 rounded-4 border-0 animate__animated animate__shakeX">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> Por favor, insira um número de pedido válido.
                    </div>
                }
            </div>
        </div>

        <div class="mt-5 pt-4">
            <div class="d-flex justify-content-center gap-4 text-muted">
                <div class="text-center">
                    <div class="bg-light rounded-circle p-3 mb-2 mx-auto" style="width: 60px;">
                        <i class="bi bi-credit-card-2-back fs-4"></i>
                    </div>
                    <small>1. Pague</small>
                </div>
                <div class="text-center">
                    <div class="bg-light rounded-circle p-3 mb-2 mx-auto" style="width: 60px;">
                        <i class="bi bi-fire fs-4"></i>
                    </div>
                    <small>2. Preparo</small>
                </div>
                <div class="text-center">
                    <div class="bg-light rounded-circle p-3 mb-2 mx-auto" style="width: 60px;">
                        <i class="bi bi-bicycle fs-4"></i>
                    </div>
                    <small>3. Entrega</small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .glass-panel {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .hover-scale {
        transition: transform 0.2s;
    }

    .hover-scale:hover:not(:disabled) {
        transform: scale(1.02);
    }
    
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }
</style>

@code {
    private int pedidoId;
    private bool erro = false;

    private void VerPedido()
    {
        if (pedidoId > 0)
        {
            Navigation.NavigateTo($"/pedido/{pedidoId}");
        }
        else
        {
            erro = true;
        }
    }

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            VerPedido();
        }
    }
}
